<h1>Contrat <%= @contract.reference %></h1>

<dl>
  <dt>Client</dt><dd><%= @contract.client&.name %></dd>
  <dt>Signé le</dt><dd><%= @contract.signed_on %></dd>
  <dt>Valeur</dt><dd><%= number_to_currency(@contract.value_cents.to_i / 100, unit: "€", format: "%n %u") %></dd>
  <dt>Statut</dt><dd><%= @contract.status %></dd>
</dl>

<p><%= link_to "Retour", contracts_path %></p>
