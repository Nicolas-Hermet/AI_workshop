<h1>Départements</h1>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr><th>Code</th><th>Nom</th><th>Effectif</th><th>Budget</th><th></th></tr>
  </thead>
  <tbody>
    <% @departments.each do |department| %>
      <tr>
        <td><%= department.code %></td>
        <td><%= department.name %></td>
        <td><%= department.headcount %></td>
        <td><%= number_to_currency(department.budget_cents.to_i / 100, unit: "€", format: "%n %u") %></td>
        <td><%= link_to "Voir", department_path(department) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
