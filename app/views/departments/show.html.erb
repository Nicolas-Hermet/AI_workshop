<h1><%= @department.name %></h1>

<dl>
  <dt>Code</dt><dd><%= @department.code %></dd>
  <dt>Effectif</dt><dd><%= @department.headcount %></dd>
  <dt>Budget</dt><dd><%= number_to_currency(@department.budget_cents.to_i / 100, unit: "€", format: "%n %u") %></dd>
</dl>

<h2>Employés (<%= @department.employees.count %>)</h2>
<ul>
  <% @department.employees.order(:last_name).each do |employee| %>
    <li><%= link_to employee.full_name, employee_path(employee) %> — <%= employee.job_title %></li>
  <% end %>
</ul>

<p><%= link_to "Retour", departments_path %></p>
