<%= form_with model: mission do |f| %>
  <% if mission.errors.any? %>
    <div style="color:#c00;">
      <ul>
        <% mission.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <p>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </p>

  <p>
    <%= f.label :client_id, "Client" %><br>
    <%= f.collection_select :client_id, @clients, :id, :name, include_blank: true %>
  </p>

  <p>
    <%= f.label :hours, "Heures" %><br>
    <%= f.number_field :hours %>
  </p>

  <p>
    <%= f.label :hourly_rate, "Taux horaire (€)" %><br>
    <%= f.number_field :hourly_rate %>
  </p>

  <p>
    <%= f.label :private_notes, "Notes privées" %><br>
    <%= f.text_area :private_notes, rows: 4, cols: 60 %>
  </p>

  <p><%= f.submit %></p>
<% end %>
