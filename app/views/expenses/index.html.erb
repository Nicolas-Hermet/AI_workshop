<h1>Notes de frais</h1>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr><th>Date</th><th>Employé</th><th>Catégorie</th><th>Montant</th><th>Statut</th><th></th></tr>
  </thead>
  <tbody>
    <% @expenses.each do |expense| %>
      <tr>
        <td><%= expense.spent_on %></td>
        <td><%= expense.employee&.full_name %></td>
        <td><%= expense.category %></td>
        <td><%= number_to_currency(expense.amount_cents.to_i / 100, unit: "€", format: "%n %u") %></td>
        <td><%= expense.status %></td>
        <td><%= link_to "Voir", expense_path(expense) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
