<h1>Clients</h1>

<%= form_with url: clients_path, method: :get, local: true do |f| %>
  <%= f.text_field :q, placeholder: "Rechercher par nom...", value: params[:q] %>
  <%= f.submit "Chercher" %>
<% end %>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr>
      <th>Nom</th>
      <th>Contact</th>
      <th>Secteur</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    <% @clients.each do |client| %>
      <tr>
        <td><%= client.name %></td>
        <td><%= client.contact_email %></td>
        <td><%= client.industry %></td>
        <td><%= client.notes %></td>
      </tr>
    <% end %>
  </tbody>
</table>
